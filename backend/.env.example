# Railway MySQL (MySQL 플러그인 추가 시 자동 주입)
# mysql:// 형식도 자동으로 mysql+pymysql:// 로 변환됩니다
DATABASE_URL=mysql+pymysql://user:password@host:3306/railway

# CORS (커스텀 도메인 사용 시)
CORS_ORIGINS=

# Cloudflare R2
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key
R2_SECRET_ACCESS_KEY=your_r2_secret_key
R2_BUCKET_NAME=haral-shop
R2_PUBLIC_BASE_URL=https://pub-xxxx.r2.dev

# 관리자 API 키 (상품 등록/이미지 업로드)
ADMIN_API_KEY=change-me-to-a-long-random-string
